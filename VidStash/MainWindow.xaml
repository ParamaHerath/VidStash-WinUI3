<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="VidStash.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VidStash"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="VidStash">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.Resources>
            <!-- Compact Button Style for Titlebar -->
            <Style x:Key="TitleBarButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Width" Value="32" />
                <Setter Property="Height" Value="32" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Padding" Value="0" />
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="48" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="0" Margin="4,0,0,0" VerticalAlignment="Center">
                <!-- Back Button (hidden by default) -->
                <Button x:Name="BackButton"
                        Style="{StaticResource TitleBarButtonStyle}"
                        VerticalAlignment="Center"
                        Visibility="Collapsed"
                        Click="BackButton_Click"
                        ToolTipService.ToolTip="Back">
                    <FontIcon Glyph="&#xE72B;" FontSize="12" />
                </Button>

                <!-- Hamburger Button -->
                <Button x:Name="HamburgerButton"
                        Style="{StaticResource TitleBarButtonStyle}"
                        Click="HamburgerButton_Click"
                        ToolTipService.ToolTip="Toggle navigation">
                    <FontIcon Glyph="&#xE700;" FontSize="12" />
                </Button>

                <!-- App Icon + Title with animation -->
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="8,0,0,0">
                    <StackPanel.RenderTransform>
                        <TranslateTransform x:Name="AppTitleTransform" X="0" />
                    </StackPanel.RenderTransform>

                    <Image Source="ms-appx:///Assets/Square44x44Logo.targetsize-16.png" Width="16" Height="16" />
                    <TextBlock Text="VidStash" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>

            <!-- Search Bar -->
            <AutoSuggestBox x:Name="TitleBarSearchBox"
                            Grid.Column="1"
                            PlaceholderText="Search movies and series..."
                            QueryIcon="Find"
                            MinWidth="300"
                            MaxWidth="500"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            Margin="160,0,150,0"
                            TextChanged="TitleBarSearchBox_TextChanged" />
        </Grid>

        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            PaneDisplayMode="Left"
            OpenPaneLength="220"
            BackRequested="NavView_BackRequested"
            SelectionChanged="NavView_SelectionChanged"
            ItemInvoked="NavView_ItemInvoked"
            IsSettingsVisible="True">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Movies" Tag="Movies" Icon="Video" />
                <NavigationViewItem Content="TV Series" Tag="Series" Icon="SlideShow" />
                <NavigationViewItem Content="Unwatched" Tag="Unwatched">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7B3;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItemSeparator />
                <NavigationViewItemHeader Content="Folders" />
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Add Folder" Tag="AddFolder" SelectsOnInvoked="False">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE710;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Refresh Library" Tag="RefreshLibrary" SelectsOnInvoked="False">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE72C;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Grid>
                <Frame x:Name="ContentFrame" />
                <InfoBar x:Name="ScanToastInfoBar"
                         VerticalAlignment="Bottom"
                         HorizontalAlignment="Center"
                         Margin="0,0,0,16"
                         IsOpen="False"
                         IsClosable="True"
                         CornerRadius="8"
                         MaxWidth="450" />
            </Grid>
        </NavigationView>
    </Grid>
</Window>
