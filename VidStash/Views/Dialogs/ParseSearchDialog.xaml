<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="VidStash.Views.Dialogs.ParseSearchDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:VidStash.Helpers"
    PrimaryButtonText="Select"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    IsPrimaryButtonEnabled="False"
    CornerRadius="12">

    <ContentDialog.Resources>
        <helpers:PosterUrlConverter x:Key="PosterUrlConverter" />
        <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    </ContentDialog.Resources>

    <!-- Custom title bar with close X button -->
    <ContentDialog.TitleTemplate>
        <DataTemplate>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE721;" FontSize="18" VerticalAlignment="Center"
                              Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                    <TextBlock Text="Search TMDB" FontSize="20" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>
                <Button Grid.Column="1"
                        x:Name="TitleCloseButton"
                        Click="TitleClose_Click"
                        Width="32" Height="32"
                        Padding="0"
                        CornerRadius="16"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE711;" FontSize="12" />
                </Button>
            </Grid>
        </DataTemplate>
    </ContentDialog.TitleTemplate>

    <!-- Fixed-size content, centered by the dialog host -->
    <Grid Width="620" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="300" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: Search bar -->
        <Grid Grid.Row="0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox"
                     Grid.Column="0"
                     PlaceholderText="Enter title to search..."
                     CornerRadius="8"
                     KeyDown="SearchBox_KeyDown"
                     TextChanged="SearchBox_TextChanged" />
            <Button x:Name="SearchButton"
                    Grid.Column="1"
                    Style="{StaticResource AccentButtonStyle}"
                    CornerRadius="8"
                    Click="SearchButton_Click"
                    IsEnabled="False"
                    Padding="16,9">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE721;" FontSize="14" />
                    <TextBlock Text="Search" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Row 1: Search type toggle -->
        <Border Grid.Row="1"
                Background="{ThemeResource ControlFillColorDefaultBrush}"
                CornerRadius="8"
                Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="Search as:" VerticalAlignment="Center"
                           Opacity="0.65" FontSize="13" />
                <RadioButton x:Name="MovieRadio" Content="Movie"
                             IsChecked="True" GroupName="SearchType"
                             VerticalAlignment="Center" />
                <RadioButton x:Name="TvRadio" Content="TV Series"
                             GroupName="SearchType"
                             VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Row 2: Progress bar (Collapsed until searching) -->
        <ProgressBar Grid.Row="2"
                     x:Name="SearchProgress"
                     IsIndeterminate="True"
                     Visibility="Collapsed"
                     CornerRadius="2" />

        <!-- Row 3: No-results label (Collapsed by default) -->
        <Border Grid.Row="3"
                x:Name="NoResultsContainer"
                Background="{ThemeResource ControlFillColorDefaultBrush}"
                CornerRadius="8"
                Padding="16,12"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                <FontIcon Glyph="&#xE9CE;" FontSize="16" Opacity="0.5" VerticalAlignment="Center" />
                <TextBlock x:Name="NoResultsText"
                           Text="No results found. Try a different search term."
                           Opacity="0.6" FontSize="13"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Row 4: Results scroll area (fixed 300px height) -->
        <Border Grid.Row="4"
                x:Name="ResultsContainer"
                Visibility="Collapsed"
                CornerRadius="8"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
            <ScrollViewer x:Name="ResultsScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="ResultsPanel" Spacing="6" Padding="8" />
            </ScrollViewer>
        </Border>

        <!-- Row 5: Selected result preview -->
        <Border Grid.Row="5"
                x:Name="SelectionPreview"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                BorderThickness="1.5"
                CornerRadius="8"
                Padding="14"
                Visibility="Collapsed">
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Mini poster -->
                <Border Grid.Column="0" CornerRadius="6" Width="60" Height="90">
                    <Border.Background>
                        <ImageBrush x:Name="PreviewPosterBrush" Stretch="UniformToFill" />
                    </Border.Background>
                </Border>

                <!-- Info -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="5">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                CornerRadius="6" Padding="8,3">
                            <TextBlock Text="Selected" FontSize="11" FontWeight="Bold" Foreground="White" />
                        </Border>
                        <TextBlock x:Name="PreviewTitle"
                                   FontSize="15" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" MaxLines="1" />
                    </StackPanel>
                    <TextBlock x:Name="PreviewYear" Opacity="0.55" FontSize="12" />
                    <TextBlock x:Name="PreviewOverview"
                               Opacity="0.75" FontSize="12" LineHeight="18"
                               TextTrimming="CharacterEllipsis" MaxLines="3"
                               TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</ContentDialog>
