<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="VidStash.Views.Dialogs.ParseSearchDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Search TMDB"
    PrimaryButtonText="Select"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    IsPrimaryButtonEnabled="False"
    CornerRadius="8"
    >

    <!-- Round the built-in bottom buttons -->
    <ContentDialog.PrimaryButtonStyle>
        <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
            <Setter Property="CornerRadius" Value="4" />
        </Style>
    </ContentDialog.PrimaryButtonStyle>
    <ContentDialog.CloseButtonStyle>
        <Style TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="CornerRadius" Value="4" />
        </Style>
    </ContentDialog.CloseButtonStyle>

    <!-- Content: stretches to whatever width the dialog host allocates -->
    <StackPanel Spacing="12" Width="460">

        <!-- Search bar + button -->
        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox"
                     Grid.Column="0"
                     CornerRadius="4"
                     PlaceholderText="Enter title to search..."
                     KeyDown="SearchBox_KeyDown"
                     TextChanged="SearchBox_TextChanged" />
            <Button x:Name="SearchButton"
                    Grid.Column="1"
                    Style="{StaticResource AccentButtonStyle}"
                    CornerRadius="4"
                    Padding="14,8"
                    Click="SearchButton_Click"
                    IsEnabled="False">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE721;" FontSize="13" />
                    <TextBlock Text="Search" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Progress bar -->
        <ProgressBar x:Name="SearchProgress"
                     IsIndeterminate="True"
                     Visibility="Collapsed"
                     CornerRadius="2" />

        <!-- No-results notice -->
        <Border x:Name="NoResultsContainer"
                Background="{ThemeResource ControlFillColorDefaultBrush}"
                CornerRadius="4"
                Padding="14,10"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                <FontIcon Glyph="&#xE9CE;" FontSize="15" Opacity="0.5" VerticalAlignment="Center" />
                <TextBlock Text="No results found. Try a different search term."
                           Opacity="0.6" FontSize="13" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Results — fixed height, always scrollable -->
        <Border x:Name="ResultsContainer"
                Visibility="Collapsed"
                CornerRadius="4"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Height="320">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="ResultsPanel" Spacing="8" />
            </ScrollViewer>
        </Border>

    </StackPanel>
</ContentDialog>
