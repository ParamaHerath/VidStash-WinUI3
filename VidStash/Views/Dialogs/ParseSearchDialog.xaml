<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="VidStash.Views.Dialogs.ParseSearchDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:VidStash.Helpers"
    Title="Search TMDB"
    PrimaryButtonText="Select"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    IsPrimaryButtonEnabled="False"
    MinWidth="680"
    MaxWidth="800">

    <ContentDialog.Resources>
        <helpers:PosterUrlConverter x:Key="PosterUrlConverter" />
        <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    </ContentDialog.Resources>

    <StackPanel Spacing="16" Width="680">

        <!-- Search bar -->
        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox"
                     Grid.Column="0"
                     PlaceholderText="Enter title to search..."
                     KeyDown="SearchBox_KeyDown"
                     TextChanged="SearchBox_TextChanged" />
            <Button x:Name="SearchButton"
                    Grid.Column="1"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="SearchButton_Click"
                    IsEnabled="False">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE721;" FontSize="14" />
                    <TextBlock Text="Search" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Search type selector -->
        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Search as:" VerticalAlignment="Center" Opacity="0.7" FontSize="13" />
            <RadioButton x:Name="MovieRadio" Content="Movie" IsChecked="True" GroupName="SearchType" />
            <RadioButton x:Name="TvRadio" Content="TV Series" GroupName="SearchType" />
        </StackPanel>

        <!-- Loading indicator -->
        <ProgressBar x:Name="SearchProgress"
                     IsIndeterminate="True"
                     Visibility="Collapsed" />

        <!-- No results message -->
        <TextBlock x:Name="NoResultsText"
                   Text="No results found. Try a different search term."
                   Visibility="Collapsed"
                   Opacity="0.6"
                   FontSize="13"
                   HorizontalAlignment="Center"
                   Margin="0,8" />

        <!-- Results list -->
        <ScrollViewer x:Name="ResultsScrollViewer"
                      MaxHeight="420"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="Collapsed">
            <StackPanel x:Name="ResultsPanel" Spacing="8" />
        </ScrollViewer>

        <!-- Selected result preview -->
        <Border x:Name="SelectionPreview"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Visibility="Collapsed">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" CornerRadius="4" Width="60" Height="90">
                    <Border.Background>
                        <ImageBrush x:Name="PreviewPosterBrush" Stretch="UniformToFill" />
                    </Border.Background>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                CornerRadius="4" Padding="8,3">
                            <TextBlock Text="Selected" FontSize="11" FontWeight="Bold" Foreground="White" />
                        </Border>
                        <TextBlock x:Name="PreviewTitle" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock x:Name="PreviewYear" Opacity="0.6" FontSize="13" />
                    <TextBlock x:Name="PreviewOverview"
                               Opacity="0.75" FontSize="12" LineHeight="18"
                               TextTrimming="CharacterEllipsis" MaxLines="3"
                               TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Grid>
        </Border>

    </StackPanel>
</ContentDialog>
