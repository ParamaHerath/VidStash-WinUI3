<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VidStash.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="48,24">
        <StackPanel Spacing="24" MaxWidth="800" HorizontalAlignment="Left">

            <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}" />

            <!-- TMDB API Key -->
            <StackPanel Spacing="8">
                <TextBlock Text="TMDB API Key" FontWeight="SemiBold" FontSize="16" />
                <TextBlock Text="Required for fetching movie and TV show metadata."
                           Opacity="0.7" FontSize="13" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <PasswordBox x:Name="ApiKeyBox" PlaceholderText="Enter your TMDB API key"
                                 PasswordChanged="ApiKeyBox_PasswordChanged" MaxWidth="500"
                                 HorizontalAlignment="Left" Width="500" />
                    <Button Grid.Column="1" Content="Save &amp; Test"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="SaveApiKey_Click" />
                </Grid>
                <TextBlock x:Name="ApiKeyStatusText" FontSize="13" />
            </StackPanel>

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <!-- Theme -->
            <StackPanel Spacing="8">
                <TextBlock Text="Theme" FontWeight="SemiBold" FontSize="16" />
                <RadioButtons x:Name="ThemeRadio" SelectionChanged="ThemeRadio_SelectionChanged">
                    <RadioButton Content="System default" Tag="System" />
                    <RadioButton Content="Light" Tag="Light" />
                    <RadioButton Content="Dark" Tag="Dark" />
                </RadioButtons>
            </StackPanel>

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <!-- Folder Management -->
            <StackPanel Spacing="8">
                <TextBlock Text="Library Folders" FontWeight="SemiBold" FontSize="16" />
                <TextBlock Text="Manage the folders VidStash scans for video files."
                           Opacity="0.7" FontSize="13" />
                <ListView x:Name="FoldersList" MaxHeight="300" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Path}" FontSize="12" Opacity="0.6" />
                                </StackPanel>
                                <Button Grid.Column="1" Content="Rescan" Margin="4,0"
                                        Click="RescanFolder_Click" />
                                <Button Grid.Column="2" Content="Remove"
                                        Click="RemoveFolder_Click" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <Button Content="Add Folder" Click="AddFolder_Click" />
            </StackPanel>

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <!-- Cache -->
            <StackPanel Spacing="8">
                <TextBlock Text="Image Cache" FontWeight="SemiBold" FontSize="16" />
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <TextBlock x:Name="CacheSizeText" VerticalAlignment="Center" FontSize="13" Opacity="0.7" />
                    <Button Content="Clear Cache" Click="ClearCache_Click" />
                </StackPanel>
            </StackPanel>

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <!-- Danger Zone -->
            <StackPanel Spacing="8">
                <TextBlock Text="Danger Zone" FontWeight="SemiBold" FontSize="16" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                <TextBlock Text="Clear all movies, series, episodes, and folders from the database. Your actual files will not be deleted."
                           Opacity="0.7" FontSize="13" TextWrapping="WrapWholeWords" />
                <Button x:Name="ClearDatabaseButton" Content="Clear Database" Click="ClearDatabase_Click"
                        Style="{StaticResource AccentButtonStyle}" />
            </StackPanel>

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <!-- About -->
            <StackPanel Spacing="8">
                <TextBlock Text="About" FontWeight="SemiBold" FontSize="16" />
                <TextBlock FontSize="13" Opacity="0.7">
                    <Run Text="VidStash v" /><Run x:Name="VersionText" Text="1.0.0" />
                </TextBlock>
                <TextBlock Text="This product uses the TMDB API but is not endorsed or certified by TMDB."
                           FontSize="12" Opacity="0.5" TextWrapping="WrapWholeWords" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
