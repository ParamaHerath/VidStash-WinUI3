<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VidStash.Views.MovieDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:VidStash.Helpers"
    xmlns:models="using:VidStash.Models"
    mc:Ignorable="d">

    <Page.Resources>
        <helpers:PosterUrlConverter x:Key="PosterUrlConverter" />
        <helpers:BackdropUrlConverter x:Key="BackdropUrlConverter" />
        <helpers:RatingToStarsConverter x:Key="RatingToStarsConverter" />
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <helpers:FileSizeConverter x:Key="FileSizeConverter" />
    </Page.Resources>

    <ScrollViewer>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="400" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Backdrop -->
            <Grid Grid.Row="0">
                <Image x:Name="BackdropImage" Stretch="UniformToFill" Opacity="0.4" />
                <Border>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="Transparent" Offset="0.3" />
                            <GradientStop Color="{ThemeResource SolidBackgroundFillColorBase}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </Grid>

            <!-- Movie Info Header -->
            <Grid Grid.Row="0" VerticalAlignment="Bottom" Padding="48,0,48,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Poster -->
                <Border Grid.Column="0" CornerRadius="8" Width="210" Height="315"
                        Margin="0,0,24,0">
                    <Border.Background>
                        <ImageBrush x:Name="PosterBrush" Stretch="UniformToFill" />
                    </Border.Background>
                </Border>

                <!-- Details -->
                <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Spacing="8">
                    <TextBlock x:Name="TitleText" FontSize="28" FontWeight="SemiBold"
                               TextWrapping="WrapWholeWords" />
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <TextBlock x:Name="YearText" Opacity="0.7" FontSize="16" />
                        <TextBlock x:Name="RuntimeText" Opacity="0.7" FontSize="16" />
                        <TextBlock x:Name="RatingText" FontSize="16" />
                    </StackPanel>

                    <!-- Genre Pills -->
                    <ItemsRepeater x:Name="GenrePills">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="8" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Border Background="{ThemeResource ControlFillColorDefaultBrush}"
                                        CornerRadius="12" Padding="12,4">
                                    <TextBlock Text="{x:Bind}" FontSize="12" />
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                    <!-- Action Buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <Button Style="{StaticResource AccentButtonStyle}"
                                Click="Play_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE768;" FontSize="16" />
                                <TextBlock Text="Play" />
                            </StackPanel>
                        </Button>
                        <Button Click="ToggleWatched_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE73E;" FontSize="16" />
                                <TextBlock x:Name="WatchedButtonText" Text="Mark Watched" />
                            </StackPanel>
                        </Button>
                        <Button Click="RefreshMetadata_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE72C;" FontSize="16" />
                                <TextBlock Text="Refresh" />
                            </StackPanel>
                        </Button>
                        <Button Click="ManualSearch_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE721;" FontSize="16" />
                                <TextBlock Text="Manual Search" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Tabs -->
            <Pivot Grid.Row="1" Margin="48,16,48,0">
                <PivotItem Header="Overview">
                    <StackPanel Spacing="16" Padding="0,16">
                        <TextBlock x:Name="OverviewText" TextWrapping="WrapWholeWords"
                                   FontSize="14" LineHeight="22" Opacity="0.85" />
                    </StackPanel>
                </PivotItem>

                <PivotItem Header="Recommended">
                    <GridView x:Name="RecommendationsGrid"
                              ItemsSource="{x:Bind ViewModel.Recommendations, Mode=OneWay}"
                              Padding="0,16"
                              IsItemClickEnabled="False"
                              SelectionMode="None">
                        <GridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal"
                                               ItemWidth="160" ItemHeight="280" />
                            </ItemsPanelTemplate>
                        </GridView.ItemsPanel>
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="models:TmdbMovie">
                                <Grid Width="140" Height="260" CornerRadius="8"
                                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="200" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Image Grid.Row="0"
                                           Source="{x:Bind PosterPath, Converter={StaticResource PosterUrlConverter}}"
                                           Stretch="UniformToFill" />
                                    <StackPanel Grid.Row="1" Padding="8,4" Spacing="2">
                                        <TextBlock Text="{x:Bind Title}" FontSize="12" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" MaxLines="2" />
                                        <TextBlock Text="{x:Bind VoteAverage, Converter={StaticResource RatingToStarsConverter}}"
                                                   FontSize="11" Opacity="0.6" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </PivotItem>

                <PivotItem Header="Details">
                    <StackPanel Spacing="8" Padding="0,16">
                        <TextBlock x:Name="FilePathText" FontSize="13" Opacity="0.7" IsTextSelectionEnabled="True" />
                        <TextBlock x:Name="FileSizeText" FontSize="13" Opacity="0.7" />
                        <TextBlock x:Name="TmdbIdText" FontSize="13" Opacity="0.7" />
                    </StackPanel>
                </PivotItem>
            </Pivot>

            <ProgressRing Grid.Row="2"
                          IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Width="36" Height="36"
                          HorizontalAlignment="Center" VerticalAlignment="Top"
                          Margin="0,24,0,0" />
        </Grid>
    </ScrollViewer>
</Page>
