<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VidStash.Views.MovieDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:VidStash.Helpers"
    xmlns:models="using:VidStash.Models"
    mc:Ignorable="d">

    <Page.Resources>
        <helpers:PosterUrlConverter x:Key="PosterUrlConverter" />
        <helpers:BackdropUrlConverter x:Key="BackdropUrlConverter" />
        <helpers:RatingToStarsConverter x:Key="RatingToStarsConverter" />
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <helpers:FileSizeConverter x:Key="FileSizeConverter" />
        <helpers:ReleaseDateToYearConverter x:Key="ReleaseDateToYearConverter" />
    </Page.Resources>

    <Grid>
        <ScrollViewer>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="400" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Backdrop -->
                <Grid Grid.Row="0">
                    <Image x:Name="BackdropImage" Stretch="UniformToFill" Opacity="0.4" />
                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0.3" />
                                <GradientStop Color="{ThemeResource SolidBackgroundFillColorBase}" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>

                <!-- Movie Info Header -->
                <Grid Grid.Row="0" VerticalAlignment="Bottom" Padding="48,0,48,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Poster -->
                    <Border Grid.Column="0" CornerRadius="8" Width="210" Height="315"
                            Margin="0,0,24,0">
                        <Border.Background>
                            <ImageBrush x:Name="PosterBrush" Stretch="UniformToFill" />
                        </Border.Background>
                    </Border>

                    <!-- Details -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Spacing="8">
                        <TextBlock x:Name="TitleText" FontSize="60" FontWeight="Bold"
                                   TextWrapping="WrapWholeWords" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Background="{ThemeResource ControlFillColorDefaultBrush}"
                                    CornerRadius="6" Padding="10,5">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE787;" FontSize="14" Opacity="0.7" VerticalAlignment="Center" />
                                    <TextBlock x:Name="YearText" Opacity="0.7" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Background="{ThemeResource ControlFillColorDefaultBrush}"
                                    CornerRadius="6" Padding="10,5">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE823;" FontSize="14" Opacity="0.7" VerticalAlignment="Center" />
                                    <TextBlock x:Name="RuntimeText" Opacity="0.7" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Border Background="{ThemeResource ControlFillColorDefaultBrush}"
                                    CornerRadius="6" Padding="10,5">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE735;" FontSize="14" Foreground="Gold" VerticalAlignment="Center" />
                                    <TextBlock x:Name="RatingText" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Genre Pills -->
                        <ItemsRepeater x:Name="GenrePills">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Horizontal" Spacing="8" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Border Background="{ThemeResource ControlFillColorDefaultBrush}"
                                            CornerRadius="6" Padding="12,4">
                                        <TextBlock Text="{x:Bind}" FontSize="12" FontWeight="SemiBold" />
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Grid>

                <!-- Content Sections -->
                <StackPanel Grid.Row="1" Spacing="32" Padding="48,24,48,48">

                    <!-- Action Buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Style="{StaticResource AccentButtonStyle}"
                                Click="Play_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xF5B0;" FontSize="16" />
                                <TextBlock Text="Play Movie" />
                            </StackPanel>
                        </Button>
                        <Button Click="ToggleWatched_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE73E;" FontSize="16" />
                                <TextBlock x:Name="WatchedButtonText" Text="Mark Watched" />
                            </StackPanel>
                        </Button>
                        <Button Click="RefreshMetadata_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE72C;" FontSize="16" />
                                <TextBlock Text="Refresh Metadata" />
                            </StackPanel>
                        </Button>
                        <Button Click="ManualSearch_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE721;" FontSize="16" />
                                <TextBlock Text="Parse" />
                            </StackPanel>
                        </Button>
                        <Button Click="OpenInExplorer_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE838;" FontSize="16" />
                                <TextBlock Text="Open in Explorer" />
                            </StackPanel>
                        </Button>
                        <Button Click="SearchInGoogle_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE774;" FontSize="16" />
                                <TextBlock Text="Search in Google" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Overview -->
                    <StackPanel Spacing="12">
                        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE946;" FontSize="22" VerticalAlignment="Center" />
                            <TextBlock Text="Overview" FontSize="22" FontWeight="Bold" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock x:Name="OverviewText" TextWrapping="WrapWholeWords"
                                   FontSize="14" LineHeight="22" Opacity="0.85" />
                    </StackPanel>

                    <!-- Similar Movies -->
                    <StackPanel x:Name="SimilarSection" Spacing="12" Visibility="Collapsed">
                        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE7C5;" FontSize="22" VerticalAlignment="Center" />
                            <TextBlock Text="Similar Movies" FontSize="22" FontWeight="Bold" VerticalAlignment="Center" />
                        </StackPanel>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      HorizontalScrollMode="Enabled"
                                      Padding="8,12,8,24">
                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.SimilarMovies, Mode=OneWay}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Horizontal" Spacing="12" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="models:TmdbMovie">
                                        <Grid Width="170" Height="320" CornerRadius="8"
                                              Background="Transparent"
                                              PointerEntered="TmdbCard_PointerEntered"
                                              PointerExited="TmdbCard_PointerExited">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="250" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <Grid.RenderTransform>
                                                <CompositeTransform x:Name="TmdbCardTransform" CenterX="85" CenterY="160" />
                                            </Grid.RenderTransform>

                                            <Grid Grid.Row="0" CornerRadius="8,8,0,0"
                                                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                                <Image Source="{x:Bind PosterPath, Converter={StaticResource PosterUrlConverter}}"
                                                       Stretch="UniformToFill" />

                                                <Grid x:Name="HoverOverlay" Opacity="0" CornerRadius="8,8,0,0">
                                                    <Grid.OpacityTransition>
                                                        <ScalarTransition Duration="0:0:0.2" />
                                                    </Grid.OpacityTransition>
                                                    <Border Background="Black" Opacity="0.3" CornerRadius="8,8,0,0" />
                                                    <StackPanel VerticalAlignment="Bottom" Padding="12" Spacing="4">
                                                        <TextBlock Text="{x:Bind VoteAverage, Converter={StaticResource RatingToStarsConverter}}"
                                                                   Foreground="White" FontSize="12" FontWeight="SemiBold" />
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>

                                            <StackPanel Grid.Row="1" Padding="8,6" Spacing="2"
                                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                                <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" MaxLines="2"
                                                           FontSize="13" />
                                                <TextBlock Text="{x:Bind ReleaseDate, Converter={StaticResource ReleaseDateToYearConverter}}"
                                                           Opacity="0.6" FontSize="12" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </ScrollViewer>
                    </StackPanel>

                    <!-- Recommended -->
                    <StackPanel x:Name="RecommendedSection" Spacing="12" Visibility="Collapsed">
                        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE734;" FontSize="22" VerticalAlignment="Center" />
                            <TextBlock Text="Recommended" FontSize="22" FontWeight="Bold" VerticalAlignment="Center" />
                        </StackPanel>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      HorizontalScrollMode="Enabled"
                                      Padding="8,12,8,24">
                            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Recommendations, Mode=OneWay}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Horizontal" Spacing="12" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="models:TmdbMovie">
                                        <Grid Width="170" Height="320" CornerRadius="8"
                                              Background="Transparent"
                                              PointerEntered="TmdbCard_PointerEntered"
                                              PointerExited="TmdbCard_PointerExited">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="250" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <Grid.RenderTransform>
                                                <CompositeTransform x:Name="TmdbCardTransform" CenterX="85" CenterY="160" />
                                            </Grid.RenderTransform>

                                            <Grid Grid.Row="0" CornerRadius="8,8,0,0"
                                                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                                <Image Source="{x:Bind PosterPath, Converter={StaticResource PosterUrlConverter}}"
                                                       Stretch="UniformToFill" />

                                                <Grid x:Name="HoverOverlay" Opacity="0" CornerRadius="8,8,0,0">
                                                    <Grid.OpacityTransition>
                                                        <ScalarTransition Duration="0:0:0.2" />
                                                    </Grid.OpacityTransition>
                                                    <Border Background="Black" Opacity="0.3" CornerRadius="8,8,0,0" />
                                                    <StackPanel VerticalAlignment="Bottom" Padding="12" Spacing="4">
                                                        <TextBlock Text="{x:Bind VoteAverage, Converter={StaticResource RatingToStarsConverter}}"
                                                                   Foreground="White" FontSize="12" FontWeight="SemiBold" />
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>

                                            <StackPanel Grid.Row="1" Padding="8,6" Spacing="2"
                                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                                <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" MaxLines="2"
                                                           FontSize="13" />
                                                <TextBlock Text="{x:Bind ReleaseDate, Converter={StaticResource ReleaseDateToYearConverter}}"
                                                           Opacity="0.6" FontSize="12" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </ScrollViewer>
                    </StackPanel>

                    <!-- File Information Card -->
                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="24"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8E5;" FontSize="22" VerticalAlignment="Center" />
                                <TextBlock Text="File Information" FontSize="22" FontWeight="Bold" VerticalAlignment="Center" />
                            </StackPanel>

                            <Grid ColumnSpacing="24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="Size" FontSize="12" Opacity="0.6" />
                                    <TextBlock x:Name="FileSizeText" FontSize="16" FontWeight="SemiBold" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="TMDB ID" FontSize="12" Opacity="0.6" />
                                    <TextBlock x:Name="TmdbIdText" FontSize="16" FontWeight="SemiBold" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Filename" FontSize="12" Opacity="0.6" />
                                <Border Background="{ThemeResource ControlFillColorDefaultBrush}"
                                        CornerRadius="4" Padding="12,8">
                                    <TextBlock x:Name="FilenameText" FontSize="13"
                                               IsTextSelectionEnabled="True" TextWrapping="Wrap"
                                               FontFamily="Cascadia Mono,Consolas,Courier New" />
                                </Border>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Location" FontSize="12" Opacity="0.6" />
                                <Border Background="{ThemeResource ControlFillColorDefaultBrush}"
                                        CornerRadius="4" Padding="12,8">
                                    <TextBlock x:Name="FilePathText" FontSize="13"
                                               IsTextSelectionEnabled="True" TextWrapping="Wrap"
                                               FontFamily="Cascadia Mono,Consolas,Courier New" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Loading overlay -->
        <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      Width="36" Height="36"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Grid>
</Page>
