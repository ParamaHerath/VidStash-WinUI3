<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="VidStash.Views.SeriesDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:VidStash.Helpers"
    xmlns:models="using:VidStash.Models"
    mc:Ignorable="d">

    <Page.Resources>
        <helpers:PosterUrlConverter x:Key="PosterUrlConverter" />
        <helpers:BackdropUrlConverter x:Key="BackdropUrlConverter" />
        <helpers:RatingToStarsConverter x:Key="RatingToStarsConverter" />
    </Page.Resources>

    <ScrollViewer>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="400" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Backdrop -->
            <Grid Grid.Row="0">
                <Image x:Name="BackdropImage" Stretch="UniformToFill" Opacity="0.4" />
                <Border>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="Transparent" Offset="0.3" />
                            <GradientStop Color="{ThemeResource SolidBackgroundFillColorBase}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </Grid>

            <!-- Series Info Header -->
            <Grid Grid.Row="0" VerticalAlignment="Bottom" Padding="48,0,48,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="8" Width="210" Height="315"
                        Margin="0,0,24,0">
                    <Border.Background>
                        <ImageBrush x:Name="PosterBrush" Stretch="UniformToFill" />
                    </Border.Background>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Spacing="8">
                    <TextBlock x:Name="TitleText" FontSize="28" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <TextBlock x:Name="YearText" Opacity="0.7" FontSize="16" />
                        <TextBlock x:Name="StatusText" Opacity="0.7" FontSize="16" />
                        <TextBlock x:Name="RatingText" FontSize="16" />
                    </StackPanel>
                    <TextBlock x:Name="SeasonEpCountText" Opacity="0.7" FontSize="14" />

                    <ItemsRepeater x:Name="GenrePills">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="8" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Border Background="{ThemeResource ControlFillColorDefaultBrush}"
                                        CornerRadius="12" Padding="12,4">
                                    <TextBlock Text="{x:Bind}" FontSize="12" />
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <Button Click="ToggleWatched_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE73E;" FontSize="16" />
                                <TextBlock x:Name="WatchedButtonText" Text="Mark Watched" />
                            </StackPanel>
                        </Button>
                        <Button Click="RefreshMetadata_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE72C;" FontSize="16" />
                                <TextBlock Text="Refresh" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Tabs -->
            <Pivot Grid.Row="1" Margin="48,16,48,0">
                <PivotItem Header="Overview">
                    <TextBlock x:Name="OverviewText" TextWrapping="WrapWholeWords"
                               FontSize="14" LineHeight="22" Opacity="0.85" Padding="0,16" />
                </PivotItem>

                <PivotItem Header="Episodes">
                    <StackPanel Spacing="12" Padding="0,16">
                        <!-- Season Selector -->
                        <ComboBox x:Name="SeasonCombo" Header="Season"
                                  Width="150"
                                  SelectionChanged="SeasonCombo_SelectionChanged" />

                        <!-- Episode List -->
                        <ListView x:Name="EpisodesList"
                                  ItemsSource="{x:Bind ViewModel.Episodes, Mode=OneWay}"
                                  SelectionMode="None"
                                  IsItemClickEnabled="True"
                                  ItemClick="Episode_Click">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:TvEpisode">
                                    <Grid Padding="8" ColumnSpacing="12" Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                                   FontWeight="SemiBold" Opacity="0.6"
                                                   FontSize="13">
                                            <Run Text="S" /><Run Text="{x:Bind Season}" /><Run Text="E" /><Run Text="{x:Bind Episode}" />
                                        </TextBlock>

                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" FontSize="14"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{x:Bind AirDate}" Opacity="0.5" FontSize="12" />
                                        </StackPanel>

                                        <Button Grid.Column="2" VerticalAlignment="Center"
                                                Click="PlayEpisode_Click" Tag="{x:Bind}">
                                            <FontIcon Glyph="&#xE768;" FontSize="14" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </PivotItem>

                <PivotItem Header="Details">
                    <StackPanel Spacing="8" Padding="0,16">
                        <TextBlock x:Name="TmdbIdText" FontSize="13" Opacity="0.7" />
                        <TextBlock x:Name="FolderText" FontSize="13" Opacity="0.7" IsTextSelectionEnabled="True" />
                    </StackPanel>
                </PivotItem>
            </Pivot>

            <ProgressRing Grid.Row="2"
                          IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Width="36" Height="36"
                          HorizontalAlignment="Center" VerticalAlignment="Top"
                          Margin="0,24,0,0" />
        </Grid>
    </ScrollViewer>
</Page>
